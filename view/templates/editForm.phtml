<?php require './view/templates/header.phtml'; ?>

<h1>Editar producto</h1>

<?php if (isset($producto) && $producto): ?>
    <form action="<?= BASE_URL ?>updateProducto/<?= $producto->id_producto ?>" method="POST">
        
        <label>Nombre:</label><br>
        <input type="text" name="nombre" value="<?= htmlspecialchars($producto->nombre ?? '') ?>"><br><br>
        
        <label>Descripción:</label><br>
        <input type="text" name="descripcion" value="<?= htmlspecialchars($producto->descripcion ?? '') ?>"><br><br>
        
        <label>Precio:</label><br>
        <input type="number" step="0.01" name="precio" value="<?= htmlspecialchars($producto->precio ?? '') ?>"><br><br>
        
        <input type="hidden" name="id_tipo" value="<?= htmlspecialchars($producto->id_tipo ?? '') ?>">

        <button type="submit">Guardar cambios</button>
    </form>
<?php else: ?>
    <p style="color: red;">Producto no encontrado.</p>
<?php endif; ?>

<a href="<?= BASE_URL ?>productos">← Volver</a>

<?php require './view/templates/footer.phtml'; ?>